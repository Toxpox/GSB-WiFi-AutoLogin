{
  "productName": "GSB WiFi AutoLogin",
  "version": "1.6.1",
  "identifier": "com.toxpox.gsb-wifi-autologin",
  "build": {
    "frontendDist": "../frontend"
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [
      {
        "title": "GSB WiFi AutoLogin",
        "width": 420,
        "height": 680,
        "resizable": false,
        "center": true
      }
    ],
    "security": {
      "csp": "default-src 'self'; style-src 'self' 'unsafe-inline'; img-src 'self' asset:"
    }
  },
  "bundle": {
    "active": true,
    "icon": ["icons/wifi.ico"],
    "targets": ["nsis"],
    "publisher": "Toxpox",
    "windows": {
      "nsis": {
        "languages": ["Turkish"],
        "displayLanguageSelector": false
      }
    }
  }
}
